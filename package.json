{
  "name": "care-os-v0",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "postinstall": "lefthook install",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:nuke": "docker compose down -v",
    "db:migrate": "pnpm --filter @careos/db migrate",
    "db:migrate:apply": "pnpm --filter @careos/db migrate:apply",
    "db:seed": "pnpm --filter @careos/db seed",
    "db:reboot": "pnpm db:nuke && pnpm db:up && pnpm db:migrate:apply && pnpm db:seed",
    "bootstrap": "pnpm install && pnpm db:up && pnpm db:migrate:apply && pnpm db:seed",
    "start": "node scripts/start.mjs",
    "teardown": "pnpm stop; pnpm db:nuke && rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "stop": "pkill -f 'turbo run dev' || true; lsof -ti tcp:3000,9376 | xargs kill -9 2>/dev/null || true; pnpm db:down"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.12.4",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jiti": "^2.6.1",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
