{
  "name": "@careos/inngest",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "dev": "npx --ignore-scripts=false inngest-cli@latest dev",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run"
  },
  "exports": {
    "./client": {
      "types": "./dist/client.ts",
      "default": "./dist/client.js"
    },
    "./functions/*": {
      "types": "./dist/functions/*.ts",
      "default": "./dist/functions/*.js"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.12.4",
  "dependencies": {
    "@careos/clinical": "workspace:*",
    "@standard-schema/spec": "^1.1.0",
    "inngest": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "inngest-cli": "^1.17.9",
    "vitest": "^4.1.2"
  }
}
